{
  "name": "village-express",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "turbo format",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:migrate": "turbo db:migrate",
    "db:studio": "turbo db:studio",
    "db:seed": "turbo db:seed",
    "test": "cd apps/web && npx vitest",
    "test:ui": "cd apps/web && npx vitest --ui",
    "test:e2e": "cd apps/web && npx playwright test",
    "test:e2e:ui": "cd apps/web && npx playwright test --ui"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2",
    "prettier": "^3",
    "turbo": "^2",
    "typescript": "^5"
  },
  "packageManager": "npm@10.8.2",
  "engines": {
    "node": ">=20"
  },
  "prisma": {
    "seed": "ts-node --project packages/db/tsconfig.json packages/db/seed.ts"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13"
  }
}
